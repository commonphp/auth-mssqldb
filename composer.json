{
  "name": "comphp/auth-mssqldb",
  "type": "library",
  "description": "Authentication Driver for CommonPHP which utilizes a Microsoft SQL Schema",
  "license": "MIT",
  "version": "0.3",
  "autoload": {
    "psr-4": {
      "CommonPHP\\Drivers\\Authentication\\MSSQL\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CommonPHP\\Drivers\\Authentication\\MSSQL\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.5",
    "comphp/auth": "^0.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "friendsofphp/php-cs-fixer": "^3.95"
  }
}